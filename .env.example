# คัดลอกเป็น .env แล้วเติมค่าจริง — .env ถูก gitignore ห้าม commit
SERVER_PORT=8081

POSTGRES_DB=authdb
POSTGRES_USER=auth
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5433

DB_URL=jdbc:postgresql://localhost:5433/authdb
DB_USER=auth
DB_PASSWORD=change-me
JWT_SECRET=replace-with-64-hex-chars-from-openssl-rand-hex-32
JWT_TTL_MINUTES=15
